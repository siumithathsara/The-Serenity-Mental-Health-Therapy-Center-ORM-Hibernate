<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="reportsPage" prefHeight="750.0" prefWidth="1200.0" style="-fx-background-color: #EBF5FB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.its1155_orm_course_work.controller.ReportController">
    <children>
        <AnchorPane prefHeight="80.0" style="-fx-background-color: white;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="371.0" layoutY="23.0" text="Reporting &amp; Data Analytics" textFill="#1A5276">
                    <font><Font name="Segoe UI Bold" size="28.0" /></font>
                </Label>
            </children>
        </AnchorPane>

        <TabPane fx:id="tabPaneReports" layoutY="80.0" style="-fx-tab-min-width: 200; -fx-tab-max-width: 300;" tabClosingPolicy="UNAVAILABLE" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="80.0">
            <tabs>
                <Tab fx:id="tabAdmin" text="Therapist Performance (Admin)">
                    <content>
                        <AnchorPane>
                            <children>
                                <HBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
                                    <children>
                                        <VBox prefWidth="550.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20;">
                                            <children>
                                                <Label text="Therapist Performance Summary" textFill="#1A5276"><font><Font name="Segoe UI Bold" size="18.0" /></font></Label>
                                                <TableView fx:id="tblPerformance" VBox.vgrow="ALWAYS">
                                                    <columns>
                                                        <TableColumn fx:id="colTherapist" prefWidth="150.0" text="Therapist" />
                                                        <TableColumn fx:id="colSessions" prefWidth="100.0" text="Sessions" />
                                                        <TableColumn fx:id="colRating" prefWidth="100.0" text="Avg. Rating" />
                                                        <TableColumn fx:id="colNoShow" prefWidth="100.0" text="No-Show %" />
                                                    </columns>
                                                </TableView>
                                            </children>
                                        </VBox>
                                        <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Session Statistics" textFill="#1A5276"><font><Font name="Segoe UI Bold" size="18.0" /></font></Label>
                                                <BarChart fx:id="chartSessions" VBox.vgrow="ALWAYS">
                                                    <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                                                    <yAxis><NumberAxis side="LEFT" /></yAxis>
                                                </BarChart>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <Tab fx:id="tabReceptionist" text="Financial Reports (Receptionist)">
                    <content>
                        <AnchorPane>
                            <children>
                                <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 0 20 0 20;">
                                            <children>
                                                <VBox alignment="CENTER_LEFT" spacing="5.0">
                                                    <children>
                                                        <Label text="Report Period" textFill="#7F8C8D"><font><Font name="Segoe UI Bold" size="12.0" /></font></Label>
                                                        <ComboBox fx:id="cmbPeriod" prefWidth="200.0" promptText="Current Month" />
                                                    </children>
                                                </VBox>
                                                <Button onAction="#btnGenerateFinanceReportOnAction" style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-background-radius: 8;" text="Generate Revenue Report">
                                                    <font><Font name="Segoe UI Bold" size="13.0" /></font>
                                                    <padding><Insets bottom="10.0" left="20.0" right="20.0" top="10.0" /></padding>
                                                </Button>
                                            </children>
                                        </HBox>
                                        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                                            <children>
                                                <VBox prefWidth="600.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20;">
                                                    <children>
                                                        <Label text="Payment History Tracking" textFill="#1A5276"><font><Font name="Segoe UI Bold" size="18.0" /></font></Label>
                                                        <TableView fx:id="tblFinancials" VBox.vgrow="ALWAYS">
                                                            <columns>
                                                                <TableColumn fx:id="colDate" prefWidth="120.0" text="Date" />
                                                                <TableColumn fx:id="colPatientName" prefWidth="180.0" text="Patient" />
                                                                <TableColumn fx:id="colAmount" prefWidth="120.0" text="Amount" />
                                                                <TableColumn fx:id="colMethod" prefWidth="100.0" text="Method" />
                                                            </columns>
                                                        </TableView>
                                                    </children>
                                                </VBox>
                                                <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="Revenue Trends" textFill="#1A5276"><font><Font name="Segoe UI Bold" size="18.0" /></font></Label>
                                                        <PieChart fx:id="chartRevenue" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <Tab text="Patient Therapy History (Read-only)">
                    <content>
                        <AnchorPane>
                            <children>
                                <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15;">
                                            <children>
                                                <TextField fx:id="txtHistorySearch" prefHeight="40.0" prefWidth="450.0" promptText="🔍 Search Therapy Logs by Patient Name or ID..." style="-fx-background-radius: 20;" />
                                                <Button onAction="#btnResetHistoryOnAction" style="-fx-background-color: #6A5ACD; -fx-text-fill: white; -fx-background-radius: 20;" text="Reset View">
                                                    <padding><Insets bottom="10.0" left="20.0" right="20.0" top="10.0" /></padding>
                                                </Button>
                                            </children>
                                        </HBox>
                                        <TableView fx:id="tblHistory" style="-fx-background-radius: 15;" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colHistDate" prefWidth="120.0" text="Date" />
                                                <TableColumn fx:id="colHistPatient" prefWidth="180.0" text="Patient" />
                                                <TableColumn fx:id="colHistProgram" prefWidth="200.0" text="Program" />
                                                <TableColumn fx:id="colHistTherapist" prefWidth="180.0" text="Therapist" />
                                                <TableColumn fx:id="colHistDetails" prefWidth="300.0" text="Session Summary" />
                                            </columns>
                                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                        </TableView>
                                    </children>
                                </VBox>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </children>
</AnchorPane>
