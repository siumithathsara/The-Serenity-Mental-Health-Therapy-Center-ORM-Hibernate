<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="therapistViewPage" prefHeight="750.0" prefWidth="1200.0" style="-fx-background-color: #EBF5FB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.its1155_orm_course_work.controller.TherapistPopUpController">
    <children>
        <AnchorPane prefHeight="80.0" style="-fx-background-color: white;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="387.0" layoutY="23.0" text="Available Therapists - View Only" textFill="#1A5276" AnchorPane.leftAnchor="387.0">
                    <font><Font name="Segoe UI Bold" size="28.0" /></font>
                </Label>
                <HBox alignment="CENTER_RIGHT" layoutX="780.0" layoutY="20.0" spacing="10.0" AnchorPane.rightAnchor="30.0" />
            </children>
        </AnchorPane>

        <VBox spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="100.0">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 0 25 0 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                    <children>
                        <VBox alignment="CENTER_LEFT" spacing="5.0">
                            <children>
                                <Label text="Quick Search" textFill="#7F8C8D">
                                    <font><Font name="Segoe UI Bold" size="12.0" /></font>
                                </Label>
                                <TextField fx:id="txtSearch" prefHeight="35.0" prefWidth="350.0" promptText="🔍 Search by Name, Specialization or ID..." style="-fx-background-radius: 10;" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER_LEFT" spacing="5.0">
                            <children>
                                <Label text="Filter by Working Day" textFill="#7F8C8D">
                                    <font><Font name="Segoe UI Bold" size="12.0" /></font>
                                </Label>
                                <ComboBox fx:id="cmbFilterDay" prefHeight="35.0" prefWidth="200.0" promptText="Select Day" style="-fx-background-radius: 10;" />
                            </children>
                        </VBox>

                        <Button mnemonicParsing="false" onAction="#handleResetView" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #6A5ACD; -fx-background-radius: 10; -fx-cursor: hand;" text="Reset View" textFill="WHITE">
                            <font><Font name="Segoe UI Bold" size="13.0" /></font>
                            <HBox.margin>
                                <Insets top="18.0" />
                            </HBox.margin>
                        </Button>
                    </children>
                </HBox>

                <TableView fx:id="tblTherapists" prefHeight="200.0" prefWidth="200.0" style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #dcdde1; -fx-padding: 10;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="100.0" text="ID" />
                        <TableColumn fx:id="colName" prefWidth="250.0" text="Therapist Name" />
                        <TableColumn fx:id="colSpecialization" prefWidth="220.0" text="Specialization" />
                        <TableColumn fx:id="colDay" prefWidth="150.0" text="Working Day" />
                        <TableColumn fx:id="colStatus" prefWidth="150.0" text="Availability Status" />
                        <TableColumn fx:id="colPhone" prefWidth="180.0" text="Contact Number" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>
