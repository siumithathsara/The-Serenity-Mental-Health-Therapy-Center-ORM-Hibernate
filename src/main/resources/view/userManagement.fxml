<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="userPage" prefHeight="750.0" prefWidth="1200.0" style="-fx-background-color: #EBF5FB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.its1155_orm_course_work.controller.UserManagementController">
    <children>
        <!-- 🏢 Header Section -->
        <AnchorPane prefHeight="80.0" style="-fx-background-color: white;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="428.0" layoutY="23.0" text="System User Management" textFill="#1A5276">
                    <font><Font name="Segoe UI Bold" size="28.0" /></font>
                </Label>
            </children>
        </AnchorPane>

        <!-- ⚙️ Main Content Body -->
        <AnchorPane layoutY="80.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="80.0">
            <children>
                <!-- 📝 Left Side: Registration Form -->
                <VBox prefWidth="420.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" AnchorPane.bottomAnchor="25.0" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="25.0">
                    <padding>
                        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
                    </padding>
                    <children>
                        <Label text="Register New User" textFill="#1A5276"><font><Font name="Segoe UI Bold" size="20.0" /></font></Label>
                        <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox spacing="2.0">
                                    <children>
                                        <Label text="User ID" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                        <TextField fx:id="txtUserId" editable="false" prefHeight="35.0" promptText="U001" style="-fx-background-radius: 8; -fx-background-color: #f1f2f6;" />
                                    </children>
                                </VBox>
                                <VBox spacing="2.0">
                                    <children>
                                        <Label text="Username" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                        <TextField fx:id="txtUsername" prefHeight="35.0" promptText="Enter Username" style="-fx-background-radius: 8;" />
                                    </children>
                                </VBox>
                                <VBox spacing="2.0">
                                    <children>
                                        <Label text="Full Name" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                        <TextField fx:id="txtFullName" prefHeight="35.0" promptText="Enter Full Name" style="-fx-background-radius: 8;" />
                                    </children>
                                </VBox>
                                <VBox spacing="2.0">
                                    <children>
                                        <Label text="Email Address" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                        <TextField fx:id="txtEmail" prefHeight="35.0" promptText="example@center.com" style="-fx-background-radius: 8;" />
                                    </children>
                                </VBox>
                                <VBox spacing="2.0">
                                    <children>
                                        <Label text="User Role" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                        <ComboBox fx:id="cmbRole" maxWidth="Infinity" prefHeight="35.0" promptText="Select Role" style="-fx-background-radius: 8;" />
                                    </children>
                                </VBox>

                                <HBox spacing="10.0">
                                    <children>
                                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Password" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                                <AnchorPane>
                                                    <children>
                                                        <TextField fx:id="txtPasswordVisible" managed="false" prefHeight="35.0" style="-fx-background-radius: 8; -fx-padding: 0 35 0 10;" visible="false" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />
                                                        <PasswordField fx:id="txtPassword" prefHeight="35.0" style="-fx-background-radius: 8; -fx-padding: 0 35 0 10;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />
                                                        <Button fx:id="btnPwToggle" onAction="#btnPwToggleOnAction" prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: transparent; -fx-cursor: hand;" text="👁" AnchorPane.rightAnchor="2.0" AnchorPane.topAnchor="2.0" />
                                                    </children>
                                                </AnchorPane>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- Form Action Buttons -->
                        <VBox spacing="8.0">
                            <children>
                                <Button fx:id="btnSave" maxWidth="Infinity" onAction="#handleUserSave" prefHeight="40.0" style="-fx-background-color: #27AE60; -fx-background-radius: 8; -fx-cursor: hand;" text="Create Account" textFill="WHITE"><font><Font name="Segoe UI Bold" size="14.0" /></font></Button>
                                <HBox spacing="10.0">
                                    <children>
                                        <Button fx:id="btnUpdate" maxWidth="Infinity" prefHeight="38.0" style="-fx-background-color: #2980B9; -fx-background-radius: 8; -fx-cursor: hand;" text="Update" textFill="WHITE" HBox.hgrow="ALWAYS"><font><Font name="Segoe UI Bold" size="13.0" /></font></Button>
                                        <Button fx:id="btnDelete" maxWidth="Infinity" prefHeight="38.0" style="-fx-background-color: #C0392B; -fx-background-radius: 8; -fx-cursor: hand;" text="Delete" textFill="WHITE" HBox.hgrow="ALWAYS"><font><Font name="Segoe UI Bold" size="13.0" /></font></Button>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <!-- 📊 Right Side: Search and Table View -->
                <VBox spacing="15.0" AnchorPane.bottomAnchor="25.0" AnchorPane.leftAnchor="480.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="25.0">
                    <children>
                        <!-- 🔍 Search Bar with Reset Button Integration -->
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <TextField fx:id="txtSearch" prefHeight="40.0" promptText="🔍 Search Users..." style="-fx-background-radius: 20; -fx-padding: 0 20 0 20;" HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnReset" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: #6A5ACD; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand;" text="Reset">
                                    <font><Font name="Segoe UI Bold" size="13.0" /></font>
                                </Button>
                            </children>
                        </HBox>

                        <!-- User Records Data Table -->
                        <TableView fx:id="tblUsers" style="-fx-background-radius: 15;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="80.0" text="User ID" />
                                <TableColumn fx:id="colUsername" prefWidth="120.0" text="Username" />
                                <TableColumn fx:id="colPassword" prefWidth="150.0" text="Password" />
                                <TableColumn fx:id="colEmail" prefWidth="180.0" text="Email" />
                                <TableColumn fx:id="colRole" prefWidth="100.0" text="Role" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</AnchorPane>
