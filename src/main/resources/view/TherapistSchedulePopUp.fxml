<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="650.0" style="-fx-background-color: #EBF5FB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.its1155_orm_course_work.controller.TherapistSchedulePopUpController">
    <children>
        <!-- Top Doctor Info Card -->
        <AnchorPane layoutX="20.0" layoutY="20.0" prefHeight="100.0" prefWidth="610.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <HBox alignment="CENTER_LEFT" layoutX="20.0" layoutY="10.0" spacing="20.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="10.0">
                    <children>
                        <!-- Beautiful Doctor Icon Placeholder -->
                        <VBox alignment="CENTER" prefHeight="70.0" prefWidth="70.0" style="-fx-background-color: #E8EAF6; -fx-background-radius: 50;">
                            <children>
                                <Label text="👨‍⚕️" textFill="#6a5acd">
                                    <font>
                                        <Font size="32.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                        <VBox alignment="CENTER_LEFT" spacing="4.0">
                            <children>
                                <!-- Doctor Name -->
                                <Label fx:id="lblDocName" text="Dr. Imakshi Siumi" textFill="#1A5276">
                                    <font>
                                        <Font name="Segoe UI Bold" size="20.0" />
                                    </font>
                                </Label>
                                <!-- Specialization -->
                                <Label fx:id="lblSpecialization" text="Cognitive Behavioral Therapy (CBT) Specialist" textFill="#7F8C8D">
                                    <font>
                                        <Font name="Segoe UI Semibold" size="13.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <!-- Session Counter Badge (Right Side) -->
                <VBox alignment="CENTER" layoutX="490.0" layoutY="20.0" prefHeight="60.0" prefWidth="100.0" style="-fx-background-color: #E8F8F5; -fx-background-radius: 12;" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
                    <children>
                        <Label fx:id="lblTotalSessions" text="05" textFill="#27AE60">
                            <font>
                                <Font name="Segoe UI Bold" size="22.0" />
                            </font>
                        </Label>
                        <Label text="Total Sessions" textFill="#7F8C8D">
                            <font>
                                <Font name="Segoe UI" size="11.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </AnchorPane>

        <!-- Schedule Table Label -->
        <Label layoutX="25.0" layoutY="140.0" text="Today's Time Slots" textFill="#1A5276">
            <font>
                <Font name="Segoe UI Bold" size="15.0" />
            </font>
        </Label>

        <!-- Table View -->
        <TableView fx:id="tblDoctorSchedule" layoutX="20.0" layoutY="170.0" prefHeight="350.0" prefWidth="610.0" style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #dcdde1;" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="170.0">
            <columns>
                <TableColumn fx:id="colTime" prefWidth="130.0" text="Time Slot" />
                <TableColumn fx:id="colPatient" prefWidth="300.0" text=" Patient Name" />
                <TableColumn fx:id="colStatus" prefWidth="150.0" text=" Status" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </children>
</AnchorPane>