<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="patientPage" prefHeight="750.0" prefWidth="1200.0" style="-fx-background-color: #EBF5FB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.its1155_orm_course_work.controller.PatientManagementController">
    <children>

        <AnchorPane prefHeight="80.0" style="-fx-background-color: white;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="450.6" layoutY="23.2" text="Patient Management" textFill="#080b8e" AnchorPane.leftAnchor="450.6" AnchorPane.topAnchor="23.2">
                    <font><Font name="Segoe UI Bold" size="28.0" /></font>
                </Label>
            </children>
        </AnchorPane>

        <AnchorPane layoutY="80.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="80.0">
            <children>

                <VBox prefWidth="400.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="30.0">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                    </padding>
                    <children>
                        <Label text="Patient Registration" textFill="#1A5276">
                            <font><Font name="Segoe UI Bold" size="18.0" /></font>
                        </Label>

                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label text="Patient ID" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="12.0" /></font></Label>
                                        <TextField fx:id="txtPatientId" onKeyPressed="#handlePatientSearch" prefHeight="38.0" promptText="P001" style="-fx-background-radius: 8;" />
                                    </children>
                                </VBox>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label text="Full Name" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="12.0" /></font></Label>
                                        <TextField fx:id="txtPatientName" prefHeight="38.0" promptText="Enter full name" style="-fx-background-radius: 8;" />
                                    </children>
                                </VBox>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label text="NIC / Passport" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="12.0" /></font></Label>
                                        <TextField fx:id="txtNic" prefHeight="38.0" promptText="Enter NIC number" style="-fx-background-radius: 8;" />
                                    </children>
                                </VBox>

                                <VBox spacing="3.0">
                                    <children>
                                        <Label text="Phone Number" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="12.0" /></font></Label>
                                        <TextField fx:id="txtPhone" prefHeight="38.0" promptText="Ex: 0771234567" style="-fx-background-radius: 8;" />
                                    </children>
                                </VBox>

                                <VBox spacing="3.0" />
                                <VBox prefHeight="127.0" prefWidth="350.0" spacing="3.0">
                                    <children>
                              <Label text="Address" textFill="#7F8C8D">
                                 <font>
                                    <Font name="Segoe UI Semibold" size="12.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtAddress" prefHeight="38.0" promptText="Enter Address" style="-fx-background-radius: 8;" />
                                        <Label text="Registration Date" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="12.0" /></font></Label>
                                        <DatePicker fx:id="dtpRegDate" maxWidth="Infinity" prefHeight="38.0" style="-fx-background-radius: 8;" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox spacing="10.0">
                            <children>
                                <HBox spacing="10.0">
                                    <children>
                                        <Button fx:id="btnSave" maxWidth="Infinity" onAction="#handlePatientSave" prefHeight="42.0" style="-fx-background-color: #27AE60; -fx-background-radius: 8; -fx-cursor: hand;" text="Register" textFill="WHITE" HBox.hgrow="ALWAYS">
                                            <font><Font name="Segoe UI Bold" size="13.0" /></font>
                                        </Button>
                                        <Button fx:id="btnUpdate" maxWidth="Infinity" onAction="#handlePatientUpdate" prefHeight="42.0" style="-fx-background-color: #2980B9; -fx-background-radius: 8; -fx-cursor: hand;" text="Update" textFill="WHITE" HBox.hgrow="ALWAYS">
                                            <font><Font name="Segoe UI Bold" size="13.0" /></font>
                                        </Button>
                                    </children>
                                </HBox>
                                <Button fx:id="btnDelete" maxWidth="Infinity" onAction="#handlePatientDelete" prefHeight="42.0" style="-fx-background-color: #C0392B; -fx-background-radius: 8; -fx-cursor: hand;" text="Remove Patient" textFill="WHITE">
                                    <font><Font name="Segoe UI Bold" size="13.0" /></font>
                                </Button>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="460.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <TextField fx:id="txtSearch" prefHeight="40.0" prefWidth="400.0" promptText="🔍 Search Patient by NIC or Phone..." style="-fx-background-radius: 20; -fx-padding: 0 20 0 20;" />
                                <Button mnemonicParsing="false" onAction="#handlePatientReset" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: #6A5ACD; -fx-background-radius: 20; -fx-cursor: hand;" text="Reset" textFill="WHITE">
                                    <font><Font name="Segoe UI Bold" size="13.0" /></font>
                                </Button>
                            </children>
                        </HBox>

                        <TableView fx:id="tblPatients" prefHeight="200.0" prefWidth="200.0" style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #dcdde1;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" maxWidth="60.0" minWidth="50.0" prefWidth="55.0" text="ID" />
                                <TableColumn fx:id="colName" prefWidth="150.0" text="Full Name" />
                                <TableColumn fx:id="colNic" prefWidth="110.0" text="NIC" />
                                <TableColumn fx:id="colPhone" prefWidth="110.0" text="Phone" />
                                <TableColumn fx:id="colAddress" prefWidth="140.0" text="Address" />
                                <TableColumn fx:id="colDate" prefWidth="100.0" text="Reg. Date" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

            </children>
        </AnchorPane>
    </children>
</AnchorPane>
