<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="paymentPage" prefHeight="750.0" prefWidth="1200.0" style="-fx-background-color: #EBF5FB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.its1155_orm_course_work.controller.PaymentController">
    <children>
        <AnchorPane prefHeight="80.0" style="-fx-background-color: white;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="356.0" layoutY="23.0" text="Payment Processing &amp; Billing" textFill="#1A5276">
                    <font><Font name="Segoe UI Bold" size="28.0" /></font>
                </Label>
            </children>
        </AnchorPane>

        <AnchorPane layoutY="80.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="80.0">
            <children>
                <VBox prefWidth="420.0" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="30.0">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="20.0" />
                    </padding>
                    <children>
                        <Label text="Process New Payment" textFill="#1A5276">
                            <font><Font name="Segoe UI Bold" size="20.0" /></font>
                        </Label>

                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox spacing="10.0">
                                    <children>
                                        <VBox HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Invoice No" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                                <TextField fx:id="txtInvoiceNo" editable="false" prefHeight="35.0" promptText="INV-0001" style="-fx-background-radius: 8; -fx-background-color: #f1f2f6;" />
                                            </children>
                                        </VBox>
                                        <VBox HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Date" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                                <TextField fx:id="txtDate" editable="false" prefHeight="35.0" style="-fx-background-radius: 8; -fx-background-color: #f1f2f6;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox spacing="2.0">
                                    <children>
                                        <Label text="Appointment ID" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                        <ComboBox fx:id="cmbPaymentMethod" maxWidth="Infinity" prefHeight="35.0" promptText="Select Appoinment ID" style="-fx-background-radius: 8;" />
                                    </children>
                                </VBox>

                                <VBox spacing="2.0">
                                    <children>
                                        <Label text="Patient Name" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                        <TextField fx:id="txtPatientName" editable="false" prefHeight="35.0" style="-fx-background-radius: 8; -fx-background-color: #f1f2f6;" />
                                    </children>
                                </VBox>

                                <VBox spacing="2.0">
                                    <children>
                                        <Label text="Amount (LKR)" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                        <TextField fx:id="txtAmount" editable="false" prefHeight="35.0" style="-fx-background-radius: 8; -fx-background-color: #f1f2f6; -fx-text-fill: #C0392B; -fx-font-weight: bold;" />
                                    </children>
                                </VBox>

                                <VBox spacing="2.0">
                                    <children>
                                        <Label text="Payment Method" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                    </children>
                                </VBox>
                        <ComboBox fx:id="cmbPaymentMethod1" maxWidth="Infinity" prefHeight="35.0" promptText="Select Method" style="-fx-background-radius: 8;" />
                            </children>
                        </VBox>

                        <VBox spacing="10.0">
                            <children>
                                <Button fx:id="btnProcess" maxWidth="Infinity" prefHeight="45.0" style="-fx-background-color: #27AE60; -fx-background-radius: 8; -fx-cursor: hand;" text="Process &amp; Print Invoice" textFill="WHITE">
                                    <font><Font name="Segoe UI Bold" size="15.0" /></font>
                                </Button>
                                <Button fx:id="btnClear" maxWidth="Infinity" prefHeight="35.0" style="-fx-background-color: #7F8C8D; -fx-background-radius: 8; -fx-cursor: hand;" text="Clear Fields" textFill="WHITE">
                                    <font><Font name="Segoe UI Bold" size="12.0" /></font>
                                </Button>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox spacing="15.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="480.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <TextField fx:id="txtSearch" prefHeight="40.0" prefWidth="350.0" promptText="🔍 Search Transactions (Inv No / Patient)..." style="-fx-background-radius: 20; -fx-padding: 0 20 0 20;" />
                            </children>
                        </HBox>

                        <TableView fx:id="tblPayments" style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #dcdde1;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colInvNo" prefWidth="90.0" text="Inv No" />
                                <TableColumn fx:id="colAppId" prefWidth="90.0" text="App ID" />
                                <TableColumn fx:id="colPatient" prefWidth="150.0" text="Patient Name" />
                                <TableColumn fx:id="colAmount" prefWidth="120.0" text="Amount (LKR)" />
                                <TableColumn fx:id="colMethod" prefWidth="110.0" text="Method" />
                                <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</AnchorPane>
