<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="schedulingPage" prefHeight="750.0" prefWidth="1200.0" style="-fx-background-color: #EBF5FB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.its1155_orm_course_work.controller.TherapySessionController">
    <children>
        <AnchorPane prefHeight="80.0" style="-fx-background-color: white;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="272.0" layoutY="24.0" text="Therapy Session Scheduling &amp; Appointments" textFill="#1A5276">
                    <font><Font name="Segoe UI Bold" size="26.0" /></font>
                </Label>
            </children>
        </AnchorPane>

        <AnchorPane layoutY="80.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="80.0">
            <children>
                <VBox prefWidth="440.0" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" AnchorPane.bottomAnchor="25.0" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="25.0">
                    <padding>
                        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
                    </padding>
                    <children>
                        <Label text="Book New Appointment" textFill="#1A5276">
                            <font><Font name="Segoe UI Bold" size="18.0" /></font>
                        </Label>

                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox spacing="10.0">
                                    <children>
                                        <VBox HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Appointment ID" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                                <TextField fx:id="txtAppointmentId" onKeyPressed="#handleSessionSearch" prefHeight="35.0" promptText="APP-001" style="-fx-background-radius: 8; -fx-background-color: #f1f2f6;" />
                                            </children>
                                        </VBox>
                                        <VBox HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Current Status" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                                <ComboBox fx:id="cmbStatus" maxWidth="Infinity" prefHeight="35.0" promptText="Select Status" style="-fx-background-radius: 8;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox spacing="10.0">
                                    <children>
                                        <VBox prefWidth="120.0">
                                            <children>
                                                <Label text="Patient ID" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                    <ComboBox fx:id="cmbStatus1" maxWidth="Infinity" onAction="#handleSelectPatientId" prefHeight="35.0" promptText="Select  ID" style="-fx-background-radius: 8;" />
                                            </children>
                                        </VBox>
                                        <VBox HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Patient Name" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                                <TextField fx:id="txtPatientName" editable="false" prefHeight="35.0" promptText="Patient Name Display Here" style="-fx-background-radius: 8; -fx-background-color: #f1f2f6;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox spacing="2.0">
                                    <children>
                                        <Label text="Select Therapy Program" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                        <ComboBox fx:id="cmbProgram" maxWidth="Infinity" onAction="#handleSelectProgram" prefHeight="35.0" promptText="Select Therapy Program (e.g., CBT)" style="-fx-background-radius: 8;" />
                                    </children>
                                </VBox>

                                <VBox spacing="2.0">
                                    <children>
                                        <Label text="Assign Available Therapist" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                        <ComboBox fx:id="cmbTherapist" maxWidth="Infinity" onAction="#handleTherapistDate" prefHeight="35.0" promptText="Select Assigned Therapist" style="-fx-background-radius: 8;" />
                                    </children>
                                </VBox>

                                <HBox spacing="10.0">
                                    <children>
                                        <VBox HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Session Date" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                                <DatePicker fx:id="dpSessionDate" maxWidth="Infinity" onAction="#handleTimeSlot" prefHeight="35.0" style="-fx-background-radius: 8;" />
                                            </children>
                                        </VBox>
                                        <VBox HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Time Slot" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                                <ComboBox fx:id="cmbTimeSlot" maxWidth="Infinity" prefHeight="35.0" promptText="Select Time" style="-fx-background-radius: 8;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Button fx:id="btnBook" maxWidth="Infinity" onAction="#handleBookingSessionSave" prefHeight="42.0" style="-fx-background-color: #27AE60; -fx-background-radius: 8; -fx-cursor: hand;" text="Confirm &amp; Book Session" textFill="WHITE">
                                    <font><Font name="Segoe UI Bold" size="14.0" /></font>
                                </Button>
                                <HBox spacing="10.0">
                                    <children>
                                        <Button fx:id="btnReschedule" maxWidth="Infinity" onAction="#handleSessionUpdate" prefHeight="40.0" style="-fx-background-color: #2980B9; -fx-background-radius: 8; -fx-cursor: hand;" text="Reschedule" textFill="WHITE" HBox.hgrow="ALWAYS">
                                            <font><Font name="Segoe UI Bold" size="13.0" /></font>
                                        </Button>
                                        <Button fx:id="btnCancel" maxWidth="Infinity" onAction="#handleSessionDelete" prefHeight="40.0" style="-fx-background-color: #C0392B; -fx-background-radius: 8; -fx-cursor: hand;" text="Cancel Booking" textFill="WHITE" HBox.hgrow="ALWAYS">
                                            <font><Font name="Segoe UI Bold" size="13.0" /></font>
                                        </Button>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox spacing="15.0" AnchorPane.bottomAnchor="25.0" AnchorPane.leftAnchor="500.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="25.0">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <TextField fx:id="txtSearch" onAction="#handleSessionByName" prefHeight="40.0" prefWidth="350.0" promptText="🔍 Search Appointments..." style="-fx-background-radius: 20; -fx-padding: 0 20 0 20;" />
                        <Button mnemonicParsing="false" onAction="#handleSessionReset" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: #6A5ACD; -fx-background-radius: 20; -fx-cursor: hand;" text="Reset" textFill="WHITE">
                           <font>
                              <Font name="Segoe UI Bold" size="13.0" />
                           </font>
                        </Button>
                            </children>
                        </HBox>
                        <TableView fx:id="tblAppointments" style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #dcdde1;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="70.0" text="App ID" />
                                <TableColumn fx:id="colPatient" prefWidth="130.0" text="Patient Name" />
                                <TableColumn fx:id="colProgram" prefWidth="120.0" text="Program" />
                                <TableColumn fx:id="colTherapist" prefWidth="120.0" text="Therapist" />
                                <TableColumn fx:id="colDateTime" prefWidth="150.0" text="Date/Time" />
                                <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</AnchorPane>
