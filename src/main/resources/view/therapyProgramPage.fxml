<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="programPage" prefHeight="750.0" prefWidth="1200.0" style="-fx-background-color: #EBF5FB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.its1155_orm_course_work.controller.TherapyProgramManagementController">
    <children>
        <AnchorPane prefHeight="80.0" style="-fx-background-color: white;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="355.0" layoutY="24.0" text="Therapy Program Management" textFill="#1A5276">
                    <font><Font name="Segoe UI Bold" size="26.0" /></font>
                </Label>
            </children>
        </AnchorPane>

        <AnchorPane layoutY="80.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="80.0">
            <children>
                <VBox prefWidth="420.0" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="30.0">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="20.0" />
                    </padding>
                    <children>
                        <Label text="Manage Program Details" textFill="#1A5276">
                            <font><Font name="Segoe UI Bold" size="18.0" /></font>
                        </Label>

                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox spacing="2.0">
                                    <children>
                                        <Label text="Program ID" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                        <TextField fx:id="txtProgramId" onKeyPressed="#handleProgramSearch" prefHeight="35.0" promptText="MT1001" style="-fx-background-radius: 8; -fx-background-color: #f1f2f6;" />
                                    </children>
                                </VBox>
                                <VBox spacing="2.0">
                                    <children>
                                        <Label text="Program Name" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                        <TextField fx:id="txtProgramName" prefHeight="35.0" promptText="e.g. Cognitive Behavioral Therapy" style="-fx-background-radius: 8;" />
                                    </children>
                                </VBox>
                                <HBox spacing="10.0">
                                    <children>
                                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Duration" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                                <TextField fx:id="txtDuration" prefHeight="35.0" promptText="e.g. 12 weeks" style="-fx-background-radius: 8;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Fee (LKR)" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                                <TextField fx:id="txtFee" prefHeight="35.0" promptText="80000.00" style="-fx-background-radius: 8;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <VBox spacing="2.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label text="Description" textFill="#7F8C8D"><font><Font name="Segoe UI Semibold" size="11.0" /></font></Label>
                                        <TextArea fx:id="txtDescription" prefHeight="100.0" promptText="Briefly describe the program objectives..." style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #dcdde1;" wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Button fx:id="btnSave" maxWidth="Infinity" onAction="#handleProgramSave" prefHeight="40.0" style="-fx-background-color: #27AE60; -fx-background-radius: 8; -fx-cursor: hand;" text="Add New Program" textFill="WHITE">
                                    <font><Font name="Segoe UI Bold" size="14.0" /></font>
                                </Button>
                                <HBox spacing="10.0">
                                    <children>
                                        <Button fx:id="btnUpdate" maxWidth="Infinity" onAction="#handleProgramUpdate" prefHeight="38.0" style="-fx-background-color: #2980B9; -fx-background-radius: 8; -fx-cursor: hand;" text="Update" textFill="WHITE" HBox.hgrow="ALWAYS">
                                            <font><Font name="Segoe UI Bold" size="13.0" /></font>
                                        </Button>
                                        <Button fx:id="btnDelete" maxWidth="Infinity" onAction="#handleProgramDelete" prefHeight="38.0" style="-fx-background-color: #C0392B; -fx-background-radius: 8; -fx-cursor: hand;" text="Remove" textFill="WHITE" HBox.hgrow="ALWAYS">
                                            <font><Font name="Segoe UI Bold" size="13.0" /></font>
                                        </Button>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox spacing="15.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="480.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <TextField fx:id="txtSearch" prefHeight="40.0" prefWidth="400.0" promptText="🔍 Search programs..." style="-fx-background-radius: 20; -fx-padding: 0 20 0 20;" />
                        <Button mnemonicParsing="false" onAction="#handleResetBtn" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: #6A5ACD; -fx-background-radius: 20; -fx-cursor: hand;" text="Reset" textFill="WHITE">
                           <font>
                              <Font name="Segoe UI Bold" size="13.0" />
                           </font>
                        </Button>
                            </children>
                        </HBox>

                        <TableView fx:id="tblPrograms" style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #dcdde1;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="90.0" text="Prog. ID" />
                                <TableColumn fx:id="colName" prefWidth="220.0" text="Program Name" />
                                <TableColumn fx:id="colDuration" prefWidth="120.0" text="Duration" />
                                <TableColumn fx:id="colFee" prefWidth="130.0" text="Fee (LKR)" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</AnchorPane>
